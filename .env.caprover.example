# Copy to .env.caprover (gitignored) and fill in your CapRover values.
#
# App token (recommended): CapRover → your app → Deployment → App Tokens
# Root password: CapRover dashboard login (less ideal for CI/local scripts)

CAPROVER_URL=https://captain.example.com
CAPROVER_APP=callcenter

# Prefer app token over root password:
CAPROVER_APP_TOKEN=
# CAPROVER_PASSWORD=

# Optional: machine alias from `npx caprover login`
# CAPROVER_NAME=production

# Optional: deploy a specific git branch (uncommitted / ignored files are excluded)
# CAPROVER_BRANCH=main
